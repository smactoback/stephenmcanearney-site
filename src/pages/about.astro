---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL } from '../consts';
---

<BaseLayout
  title="About"
  description="Stephen McAnearney — technology strategist between Sydney, SF, and the Pilbara."
>
  <main>
    <section class="hero">
      <div>
        <div class="avatar-swap">
          <img src="/assets/avatar.png" alt="Stephen McAnearney" class="avatar-base" width="240" height="240" />
          <img src="/assets/portrait.png" alt="" aria-hidden="true" class="avatar-hover" width="240" height="240" />
        </div>
        <p class="caption">
          --<br />   
        </p>
      </div>

      <div class="bio">
        <h1>Stephen McAnearney</h1>
          <h3>Western Australia ↔ NYC ↔ SF</h3>

          <p>
            Perth-born. I spent fifteen years in New York and San Francisco: first in banking
            and investing, including bringing <a href="https://www.mckinsey.com/industries/technology-media-and-telecommunications/our-insights/a-machine-learning-approach-to-venture-capital">machine learning</a> to seed VC in 2017, then seven years at
            Meta (via the CTRL-labs <a href="https://www.ft.com/content/f64bde30-de6c-11e9-9743-db5a370481bc?syn-25a6b1a6=1">acquisition</a>), where I shipped the world's first mainstream neural interface and
            contributed to work published in <a href="https://www.nature.com/articles/s41586-025-09255-w">Nature</a>. Fulbright Scholar, Columbia MSc. in
            Management Science, UWA engineering (Sir Russell Dumas Medal).
          </p>
          <p>
            Now based in Perth splitting time between Australia / NYC / SF, focused on the deep
            tech being built on Australia's physical assets, critical minerals, energy, and
            autonomous systems.
          </p>
      </div>
    </section>

    <section class="contact">
      <h2>Contact</h2>
      <ul>
        <li><a id="email-link" aria-label="Email">email —</a></li>
        <li><a href={SOCIAL.linkedin} rel="me">linkedin.com/in/stephenmcanearney</a></li>
      </ul>
      <script>
        // Assemble the address in-browser so it never appears in the raw HTML for scrapers.
        const parts = ['s.mcanearney', 'gmail', 'com'];
        const addr = parts[0] + '@' + parts[1] + '.' + parts[2];
        const link = document.getElementById('email-link');
        if (link) {
          link.setAttribute('href', 'mailto:' + addr);
          link.textContent = addr;
        }
      </script>
      <p class="colophon">Set in <span class="ac">IBM Plex Mono</span> and Newsreader.</p>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 24px var(--gutter) 56px;
    font-family: var(--font-mono);
  }
  .hero {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 40px;
    align-items: start;
  }
  .avatar-swap {
    position: relative;
    width: 240px;
    height: 240px;
    border: 1px solid var(--ink);
    overflow: hidden;
  }
  .avatar-swap img {
    width: 240px;
    height: 240px;
    image-rendering: pixelated;
    display: block;
  }
  .avatar-hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 180ms ease;
    pointer-events: none;
  }
  .avatar-swap:hover .avatar-hover { opacity: 1; }
  .caption {
    margin-top: 10px;
    font-size: 10.5px;
    opacity: 0.55;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .bio { display: flex; flex-direction: column; gap: 20px; }
  .bio h1 {
    margin: 0;
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .bio h3 {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.3;
  }
  .bio p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.6;
    max-width: 640px;
  }
  .frame {
    background: var(--paper);
    padding: 8px;
    border: 1px solid var(--rule);
  }

  .contact { margin-top: 56px; }
  .contact h2 {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0 0 14px;
  }
  .contact ul {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13.5px;
    line-height: 1.9;
  }
  .contact a {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }
  .colophon {
    margin: 18px 0 0;
    font-size: 12px;
    opacity: 0.7;
    line-height: 1.55;
  }
  .ac { color: var(--accent); }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
  }
</style>
