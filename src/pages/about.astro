---
import BaseLayout from '../layouts/BaseLayout.astro';

// Selected work. The Nature link is a placeholder — drop in the real DOI.
const work = [
  {
    title: 'Meta Neural Band',
    detail: 'Wristband that reads motor intent from surface EMG. Shipped as a Meta product.',
    href: undefined as string | undefined,
  },
  {
    title: 'Meta Ray-Ban Display',
    detail: 'Display smart glasses. Shipped as a Meta consumer product.',
    href: undefined as string | undefined,
  },
  {
    title: 'Research in Nature',
    detail: 'Co-authored work on neuromotor interfaces.',
    href: 'https://www.nature.com', // TODO: replace with the paper DOI
  },
  {
    title: 'Hone Capital',
    detail: 'Early-stage venture investing.',
    href: undefined as string | undefined,
  },
  {
    title: 'J.P. Morgan',
    detail: 'Technology, media & telecom investment banking.',
    href: undefined as string | undefined,
  },
  {
    title: 'Harvard Surgical Planning Lab',
    detail: 'Medical imaging and surgical planning research.',
    href: undefined as string | undefined,
  },
];

const education = [
  {
    school: 'Columbia University',
    detail: 'M.S., Management Science & Engineering. Fulbright Scholar.',
  },
  {
    school: 'The University of Western Australia',
    detail: 'Electrical & Electronic Engineering; Anatomy & Human Biology.',
  },
];
---

<BaseLayout
  title="About"
  description="Stephen McAnearney — from engineering and anatomy in Perth to neural interfaces at Meta, and back."
>
  <main>
    <header class="page-head">
      <p class="eyebrow">About</p>
      <h1>Stephen McAnearney</h1>
    </header>

    <div class="prose narrative">
      <p>
        I grew up in Perth, Western Australia, and studied electrical and electronic engineering
        alongside anatomy and human biology at the University of Western Australia — an unusual
        pairing that set the pattern for most of my work since: technology pointed at the human
        body.
      </p>
      <p>
        A Fulbright Scholarship took me to Columbia, where I completed a master's in Management
        Science and Engineering. Before that I spent time at the Harvard Surgical Planning Lab,
        working on medical imaging and the software that helps surgeons rehearse an operation
        before the first incision.
      </p>
      <p>
        I started my career in finance — technology, media and telecom investment banking at
        J.P. Morgan — then moved to the other side of the table as an investor at Hone Capital,
        backing early-stage companies.
      </p>
      <p>
        Most recently I was a Senior Product Manager at Meta, working on neural interfaces. I
        helped ship the Meta Neural Band, a wristband that reads motor intent from the surface of
        the skin, and the Meta Ray-Ban Display glasses. Some of that work was published in Nature.
      </p>
      <p>
        I'm now relocating to Perth. Australia has world-class research and real industrial
        advantages in the things deep tech increasingly depends on — energy, minerals, space, and
        marine systems. I want to help build that ecosystem, as an investor or as a founder.
      </p>
    </div>

    <section class="block">
      <h2 class="eyebrow">Selected work</h2>
      <ul class="entry-list">
        {
          work.map((item) => (
            <li>
              <span class="entry-title">
                {item.href ? <a href={item.href}>{item.title}</a> : item.title}
              </span>
              <span class="entry-detail">{item.detail}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="block">
      <h2 class="eyebrow">Education</h2>
      <ul class="entry-list">
        {
          education.map((item) => (
            <li>
              <span class="entry-title">{item.school}</span>
              <span class="entry-detail">{item.detail}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 72px var(--gutter) 88px;
  }
  .page-head {
    margin-bottom: 36px;
  }
  .page-head h1 {
    margin-top: 12px;
    font-size: clamp(1.9rem, 1.6rem + 1.5vw, 2.3rem);
  }
  .narrative {
    color: var(--fg);
  }
  .block {
    margin-top: 56px;
  }
  .entry-list {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    border-top: 1px solid var(--border);
  }
  .entry-list li {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .entry-title {
    font-size: 1.02rem;
    font-weight: 500;
    color: var(--fg-strong);
  }
  .entry-detail {
    font-size: 0.94rem;
    color: var(--fg-muted);
  }
</style>
