---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { dotDate } from '../../lib/format';

const posts = (await getCollection('previous')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

/** Lifted out of the chronology to the top of the list. */
const FEATURED_SLUG = 'can-you-build-a-quant-vc-fund';
const featured = posts.find((p) => p.id === FEATURED_SLUG);
// Drop it from the years below rather than list it twice.
const rest = featured ? posts.filter((p) => p.id !== featured.id) : posts;

// The archive spans nearly a decade, so the year is the useful grouping.
const years = [...new Set(rest.map((p) => p.data.pubDate.getUTCFullYear()))].sort(
  (a, b) => b - a,
);
// The range still describes the whole archive, featured post included.
const span = posts.map((p) => p.data.pubDate.getUTCFullYear());
const [first, last] = [Math.min(...span), Math.max(...span)];
---

<BaseLayout
  title="Previous Writing"
  description={`Archive of Stephen McAnearney's earlier writing, ${first}–${last}.`}
>
  <main>
    <section class="intro">
      <h1>Previous Writing</h1>
      <p>
        Earlier essays and notes, written between {first} and {last} and carried over from the
        previous site.
      </p>
    </section>

    <section class="archive">
      <div class="head">
        <span>Date</span>
        <span>Title</span>
      </div>
      {
        featured && (
          <div class="year feature">
            <h2 class="year-label accent">Featured</h2>
            <div class="rows">
              <article class="row">
                <div class="when">{dotDate(featured.data.pubDate)}</div>
                <a href={`/previous-writing/${featured.id}`} class="title-link">
                  <h3>{featured.data.title}</h3>
                </a>
              </article>
            </div>
          </div>
        )
      }
      {
        years.map((year) => (
          <div class="year">
            <h2 class="year-label">{year}</h2>
            <div class="rows">
              {rest
                .filter((p) => p.data.pubDate.getUTCFullYear() === year)
                .map((p) => (
                  <article class="row">
                    <div class="when">{dotDate(p.data.pubDate)}</div>
                    <a href={`/previous-writing/${p.id}`} class="title-link">
                      <h3>{p.data.title}</h3>
                    </a>
                  </article>
                ))}
            </div>
          </div>
        ))
      }
      {posts.length === 0 && <p class="empty">Nothing archived yet.</p>}
    </section>
  </main>
</BaseLayout>

<style>
  main {
    /* body is a column flex container, so the horizontal auto margins below
       defeat the default stretch and collapse main to shrink-to-fit — which
       centres it, indenting the content away from the header's left edge. */
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 24px var(--gutter) 56px;
    font-family: var(--font-mono);
    font-size: var(--base);
    line-height: var(--lh);
    color: var(--ink);
  }

  .intro { max-width: 720px; }
  .intro h1 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .intro p {
    margin-top: 10px;
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.8;
  }

  .archive { margin-top: 32px; }
  .head {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    margin-bottom: 10px;
    font-size: 11px;
    opacity: 0.55;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .year { margin-top: 28px; }
  .year:first-of-type { margin-top: 0; }
  .year-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    opacity: 0.55;
    padding-bottom: 8px;
  }
  /* Reads as a label in the same column as the years, but claimed by the accent
     so it does not scan as just another date heading. */
  .year-label.accent {
    color: var(--accent);
    opacity: 1;
    text-transform: uppercase;
  }
  .feature { margin-bottom: 34px; }
  .feature .row { border-top-color: color-mix(in srgb, var(--accent) 35%, transparent); }
  .feature .title-link h3 { font-size: 20px; font-weight: 600; }
  .row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    padding: 13px 0;
    border-top: 1px dashed var(--rule);
    align-items: baseline;
  }
  .when {
    font-size: 12px;
    opacity: 0.7;
    line-height: 1.4;
    font-variant-numeric: tabular-nums;
  }
  .title-link { color: var(--ink); }
  .title-link:hover { text-decoration: none; }
  .title-link h3 {
    margin: 0;
    font-size: 17px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .title-link:hover h3 {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }
  .empty { margin-top: 24px; opacity: 0.7; }

  @media (max-width: 820px) {
    .head, .row { grid-template-columns: 90px 1fr; }
  }
  @media (max-width: 560px) {
    .head { display: none; }
    .row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
