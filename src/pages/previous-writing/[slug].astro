---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { dotDate } from '../../lib/format';

export async function getStaticPaths() {
  const posts = (await getCollection('previous')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      newer: i > 0 ? posts[i - 1] : undefined,
      older: i < posts.length - 1 ? posts[i + 1] : undefined,
    },
  }));
}

const { post, newer, older } = Astro.props;
const { title, pubDate, html } = post.data;
---

<BaseLayout
  title={title}
  description={`${title} — from the archive, ${dotDate(pubDate)}.`}
  type="article"
  publishedTime={pubDate}
>
  <main>
    <article>
      <header class="head">
        <a href="/previous-writing" class="back">← Previous Writing</a>
        <h1>{title}</h1>
        <div class="meta"><time datetime={pubDate.toISOString()}>{dotDate(pubDate)}</time></div>
      </header>

      <div class="body" set:html={html} />
    </article>

    {
      (newer || older) && (
        <nav class="pager" aria-label="Archive">
          <div class="side">
            {newer && (
              <a href={`/previous-writing/${newer.id}`}>
                <span class="dir">← Newer</span>
                <span class="t">{newer.data.title}</span>
              </a>
            )}
          </div>
          <div class="side right">
            {older && (
              <a href={`/previous-writing/${older.id}`}>
                <span class="dir">Older →</span>
                <span class="t">{older.data.title}</span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 24px var(--gutter) 56px;
    font-family: var(--font-mono);
    color: var(--ink);
  }
  article { max-width: var(--prose-width); }

  .back {
    font-size: 12px;
    opacity: 0.6;
    letter-spacing: 0.04em;
  }
  .back:hover { color: var(--accent); opacity: 1; }
  .head h1 {
    margin: 14px 0 0;
    font-size: 30px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }
  .meta {
    margin-top: 10px;
    padding-bottom: 18px;
    border-bottom: 1px dashed var(--rule);
    font-size: 12px;
    opacity: 0.6;
    font-variant-numeric: tabular-nums;
  }

  /* The body is imported HTML, so it is styled by element rather than by class. */
  .body {
    margin-top: 26px;
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.65;
  }
  .body :global(p) { margin: 0 0 1.1em; }
  .body :global(h2),
  .body :global(h3) {
    font-family: var(--font-mono);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .body :global(h2) { margin: 1.8em 0 0.5em; font-size: 20px; }
  .body :global(h3) { margin: 1.6em 0 0.5em; font-size: 16px; }
  .body :global(ul),
  .body :global(ol) { margin: 0 0 1.1em; padding-left: 1.3em; }
  .body :global(li) { margin: 0 0 0.4em; }
  .body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .body :global(a:hover) { text-decoration-color: var(--accent); }
  .body :global(blockquote) {
    margin: 1.4em 0;
    padding-left: 18px;
    border-left: 2px solid var(--rule);
    font-style: italic;
    opacity: 0.85;
  }
  .body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.6em 0;
  }
  .body :global(strong) { font-weight: 600; }

  .pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: var(--prose-width);
    margin-top: 44px;
    padding-top: 18px;
    border-top: 1px dashed var(--rule);
    font-size: 12px;
  }
  .side.right { text-align: right; }
  .pager a { display: block; opacity: 0.75; }
  .pager a:hover { opacity: 1; color: var(--accent); text-decoration: none; }
  .pager .dir { display: block; opacity: 0.6; letter-spacing: 0.04em; }
  .pager .t { display: block; margin-top: 4px; line-height: 1.4; }

  @media (max-width: 560px) {
    .pager { grid-template-columns: 1fr; }
    .side.right { text-align: left; }
  }
</style>
