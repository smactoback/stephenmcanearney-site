---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostPreview from '../../components/PostPreview.astro';
import { getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();

const byYear = new Map<number, CollectionEntry<'writing'>[]>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  const bucket = byYear.get(year) ?? [];
  bucket.push(post);
  byYear.set(year, bucket);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout
  title="Writing"
  description="Thesis-style essays on deep tech, frontier hardware, and the case for building in Australia."
>
  <main>
    <header class="page-head">
      <p class="eyebrow">Writing</p>
      <h1>Ground Truth</h1>
      <p class="lead">
        Thesis-style essays on deep tech, frontier hardware, and the case for building in
        Australia.
      </p>
    </header>

    {
      years.map((year) => (
        <section class="year-group">
          <p class="eyebrow year">{year}</p>
          <div class="post-list">
            {byYear.get(year)!.map((post) => (
              <PostPreview post={post} />
            ))}
          </div>
        </section>
      ))
    }
    {posts.length === 0 && <p class="empty">Posts are on the way.</p>}
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 72px var(--gutter) 88px;
  }
  .page-head h1 {
    margin-top: 12px;
    font-size: clamp(1.9rem, 1.6rem + 1.5vw, 2.3rem);
  }
  .lead {
    margin-top: 16px;
    color: var(--fg-muted);
    max-width: 48ch;
  }
  .year-group {
    margin-top: 56px;
  }
  .year {
    color: var(--fg-faint);
  }
  .post-list {
    margin-top: 8px;
    border-top: 1px solid var(--border);
  }
  .empty {
    margin-top: 48px;
    color: var(--fg-muted);
  }
</style>
