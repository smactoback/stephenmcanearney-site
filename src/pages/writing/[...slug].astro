---
import { render } from 'astro:content';
import EssayLayout from '../../layouts/EssayLayout.astro';
import Sidenote from '../../components/Sidenote.astro';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      newer: i > 0 ? posts[i - 1] : undefined,
      older: i < posts.length - 1 ? posts[i + 1] : undefined,
    },
  }));
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
---

<EssayLayout
  slug={post.id}
  issue={post.data.issue}
  title={post.data.title}
  dek={post.data.dek}
  description={post.data.description}
  pubDate={post.data.pubDate}
  words={post.data.words}
  read={post.data.read}
  newer={newer ? { id: newer.id, title: newer.data.title } : undefined}
  older={older ? { id: older.id, title: older.data.title } : undefined}
>
  <Content components={{ Sidenote }} />
</EssayLayout>
