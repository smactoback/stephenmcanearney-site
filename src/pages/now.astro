---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content, frontmatter } from '../data/now.md';

const updated = new Date(frontmatter.updated);
const updatedLabel = updated.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout title="Now" description="What Stephen McAnearney is focused on right now.">
  <main>
    <header class="page-head">
      <p class="eyebrow">Now</p>
      <h1>What I'm focused on</h1>
      <p class="updated">
        Updated <time datetime={updated.toISOString()}>{updatedLabel}</time>
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 72px var(--gutter) 88px;
  }
  .page-head {
    margin-bottom: 40px;
  }
  .page-head h1 {
    margin-top: 12px;
    font-size: clamp(1.9rem, 1.6rem + 1.5vw, 2.3rem);
  }
  .updated {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-faint);
  }
</style>
