---
import BaseLayout from '../layouts/BaseLayout.astro';
import SquareField from '../components/art/SquareField.tsx';
import { getCollection } from 'astro:content';
import { dotDate } from '../lib/format';
import { SITE } from '../consts';

const posts = await getCollection('previous');

// Four working buckets for the archive. Order here is the display order; each
// post id lands in exactly one bucket. Anything unmapped falls to "Other".
const CATEGORIES = [
  {
    label: 'Venture & Fund Design',
    ids: [
      'thoughts-on-structuring-a-seed-fund',
      'optimizations-and-likelihoods-of-fund-returns',
      'relationship-between-number-of-portfolio-companies-and-fund-returns',
      'modeling-returns-in-venture-capital-power-law-hybrid',
      'running-the-math-on-larger-vc-portfolios',
      'adaptive-markets-based-approach-the-investing-in-venture-capital',
      'graph-theory-applications-in-early-stage-private-investment',
      'thoughts-on-fund-sizing',
      'can-you-build-a-quant-vc-fund',
      'machine-learning-in-private-investment',
      'what-value-should-an-angel-investor-provide',
    ],
  },
  {
    label: 'AI & Machine Learning',
    ids: [
      'investment-opportunities-in-ai',
      'the-a3-thesis-automation-augmentation-and-autonomy',
      'human-learning-vs-machine-learning',
      'activity-in-deep-learning-specialized-hardware-cpugputpuasic',
      'ai-future-entering-a-shared-world-of-significance',
      'dogfooding-yutoris-scouts',
      '7qy6q2b45gxkjdzc4ozeupf3n1tc2n',
    ],
  },
  {
    label: 'Building Companies',
    ids: [
      'decision-making-in-a-low-information-environment',
      'the-startup-genome',
      'notes-from-high-output-management',
      'founder-preparationdiligence-and-dynamic-balance',
      'a-framework-for-company-formation-diligence',
      'exogenous-factors-and-company-success',
      'industry-deep-dive-open-source-databases',
    ],
  },
  {
    label: 'Technology, History & Culture',
    ids: [
      'notes-the-british-industrial-revolution-in-global-perspective',
      'china-technology-development-and-the-future',
      'things-that-change-and-stay-the-same-or-the-technological-event-horizon',
      'the-end-of-our-shared-experience-in-physical-space',
      'the-power-of-networks-in-the-golden-age-of-silicon-valley',
      'modernists-and-mavericks-new-york-tech',
      'how-platform-shifts-happen-part-1-metaphors',
      'one-forking-path-pynchon-borges-and-william-gibson',
      'exploring-startup-activity-nyc-sf-030518-031218',
    ],
  },
] as const;

const byId = new Map(posts.map((p) => [p.id, p]));
// Build each group in the declared category order, posts newest-first inside.
const groups = CATEGORIES.map((c) => ({
  label: c.label,
  posts: c.ids
    .map((id) => byId.get(id))
    .filter((p) => p != null)
    .sort((a, b) => b!.data.pubDate.getTime() - a!.data.pubDate.getTime()),
}));
// Surface any post that slipped through the mapping rather than dropping it.
const mapped = new Set(CATEGORIES.flatMap((c) => c.ids));
const orphans = posts
  .filter((p) => !mapped.has(p.id))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
if (orphans.length) groups.push({ label: 'Other', posts: orphans });

// Sampled from the Yallingup Coffee Roasting Company stripe block.
const FIELD_PRIMARY = '#2ebda1';
const FIELD_SECONDARY = '#1265b3';
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <main>
    <section class="hero">
      <div class="intro">
        <p>
          <span class="name">Stephen McAnearney</span> is between Australia and NYC/SF.
          Shipped the world's first mainstream neural interface at Meta
          (<a href="https://www.nature.com/articles/s41586-025-09255-w">Nature</a>).
        </p>
        <p class="epigraph">
          “I believe that the attempt to make a thinking machine will help us greatly in
          finding out how we think ourselves.”<br />
          <span class="cite">— Alan Turing, 1951</span>
        </p>
      </div>

      <figure class="fig">
        <div class="field">
          <SquareField
            client:load
            width={378}
            height={142}
            cell={14}
            speed={120}
            tones={[FIELD_PRIMARY, FIELD_SECONDARY]}
          />
        </div>
        <figcaption>FIG. 1 — <a href="https://en.wikipedia.org/wiki/Georg_Nees">NESTED-SQUARE FIELD</a></figcaption>
      </figure>
    </section>

    <section class="archive">
      <div class="head">
        <span>Date</span>
        <span>Writing</span>
      </div>
      {
        groups.map((g) => (
          <div class="group">
            <h2 class="group-label">{g.label}</h2>
            <div class="rows">
              {g.posts.map((p) => (
                <article class="row">
                  <div class="when">{dotDate(p!.data.pubDate)}</div>
                  <a href={`/previous-writing/${p!.id}`} class="title-link">
                    <h3>{p!.data.title}</h3>
                  </a>
                </article>
              ))}
            </div>
          </div>
        ))
      }
      {posts.length === 0 && <p class="empty">Nothing archived yet.</p>}
    </section>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 24px var(--gutter) 56px;
    font-family: var(--font-mono);
    font-size: var(--base);
    line-height: var(--lh);
    color: var(--ink);
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 36px;
    align-items: start;
  }
  .intro {
    max-width: 720px;
  }
  .intro p {
    font-size: 16px;
    line-height: 1.6;
  }
  .intro p + p {
    margin-top: 1em;
  }
  .intro p + .epigraph {
    margin-top: 62px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    opacity: 0.85;
  }
  .intro .epigraph .cite {
    opacity: 0.7;
    display: inline-block;
    margin-top: 6px;
  }
  /* The global rule is `a { color: inherit; text-decoration: none }`, which would
     leave the citation undiscoverable until hover — and never, on touch. */
  .intro a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .intro a:hover {
    text-decoration-color: var(--accent);
  }
  .name {
    background: var(--accent);
    color: var(--paper);
    padding: 0 4px;
  }
  /* The UA sheet gives `figure` a `1em 40px` margin, which drops the field below
     the intro and squeezes the figure to 300px inside its 380px column, spilling
     the field into the gutter. Reset it, then drop back down to the intro's cap
     line: the field inks from its top edge, but the first line's caps sit ~9px
     into the line box, so matching the boxes would leave the art riding high. */
  .fig {
    margin: 9px 0 0;
  }
  .fig .field {
    width: 380px;
    height: 142px;
    overflow: hidden;
  }
  .fig figcaption {
    margin-top: 6px;
    font-size: 10.5px;
    opacity: 0.55;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .archive { margin-top: 40px; }
  .head {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    margin-bottom: 10px;
    font-size: 11px;
    opacity: 0.55;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .group { margin-top: 34px; }
  .group:first-of-type { margin-top: 0; }
  /* The category is the organising line now, so it carries the accent and reads
     a notch louder than the year labels it replaced. */
  .group-label {
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-bottom: 10px;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
  }
  .row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    padding: 13px 0;
    border-top: 1px dashed var(--rule);
    align-items: baseline;
  }
  .rows .row:first-child { border-top: none; }
  .when {
    font-size: 12px;
    opacity: 0.7;
    line-height: 1.4;
    font-variant-numeric: tabular-nums;
  }
  .title-link { color: var(--ink); }
  .title-link:hover { text-decoration: none; }
  .title-link h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .title-link:hover h3 {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }
  .empty { margin-top: 24px; opacity: 0.7; }

  @media (max-width: 820px) {
    .hero { grid-template-columns: 1fr; }
    .fig .field { width: 100%; max-width: 380px; }
    .head, .row { grid-template-columns: 90px 1fr; }
  }
  @media (max-width: 560px) {
    .head { display: none; }
    .row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
