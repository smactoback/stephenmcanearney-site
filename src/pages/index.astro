---
import BaseLayout from '../layouts/BaseLayout.astro';
import SquareField from '../components/art/SquareField.tsx';
import { getPublishedPosts } from '../lib/posts';
import { dotDate } from '../lib/format';
import { SITE } from '../consts';

const posts = await getPublishedPosts();

// Sampled from the Yallingup Coffee Roasting Company stripe block.
const FIELD_PRIMARY = '#2ebda1';
const FIELD_SECONDARY = '#1265b3';
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <main>
    <section class="hero">
      <div class="intro">
        <p>
          <span class="name">Stephen McAnearney</span> is between Australia and NYC/SF.
          Shipped the world's first mainstream neural interface at Meta
          (<a href="https://www.nature.com/articles/s41586-025-09255-w">Nature</a>).
        </p>
      </div>

      <figure class="fig">
        <div class="field">
          <SquareField
            client:load
            width={378}
            height={142}
            cell={14}
            speed={120}
            tones={[FIELD_PRIMARY, FIELD_SECONDARY]}
          />
        </div>
        <figcaption>FIG. 1 — <a href="https://en.wikipedia.org/wiki/Georg_Nees">NESTED-SQUARE FIELD</a></figcaption>
      </figure>
    </section>

    <section class="essays">
      <div class="head">
        <span>Date</span>
        <span>Exploration</span>
        <span class="right">time</span>
      </div>
      {
        posts.map((p) => (
          <article class="row">
            <div class="when">
              <div>{dotDate(p.data.pubDate)}</div>
            </div>
            <div class="body">
              <a href={`/writing/${p.id}`} class="title-link">
                <h3>{p.data.title}</h3>
              </a>
              <p class="dek">{p.data.dek}</p>
            </div>
            <div class="meta-right">
              <div>{p.data.read}</div>
              <div class="words">{p.data.words.toLocaleString()} wds</div>
            </div>
          </article>
        ))
      }
      {posts.length === 0 && <p class="empty">No essays yet.</p>}
    </section>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 24px var(--gutter) 56px;
    font-family: var(--font-mono);
    font-size: var(--base);
    line-height: var(--lh);
    color: var(--ink);
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 36px;
    align-items: start;
  }
  .intro {
    max-width: 720px;
  }
  .intro p {
    font-size: 16px;
    line-height: 1.6;
  }
  .intro p + p {
    margin-top: 1em;
  }
  /* The global rule is `a { color: inherit; text-decoration: none }`, which would
     leave the citation undiscoverable until hover — and never, on touch. */
  .intro a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .intro a:hover {
    text-decoration-color: var(--accent);
  }
  .name {
    background: var(--accent);
    color: var(--paper);
    padding: 0 4px;
  }
  /* The UA sheet gives `figure` a `1em 40px` margin, which drops the field below
     the intro and squeezes the figure to 300px inside its 380px column, spilling
     the field into the gutter. Reset it, then drop back down to the intro's cap
     line: the field inks from its top edge, but the first line's caps sit ~9px
     into the line box, so matching the boxes would leave the art riding high. */
  .fig {
    margin: 9px 0 0;
  }
  .fig .field {
    width: 380px;
    height: 142px;
    overflow: hidden;
  }
  .fig figcaption {
    margin-top: 6px;
    font-size: 10.5px;
    opacity: 0.55;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .essays { margin-top: 28px; }
  .head {
    display: grid;
    grid-template-columns: 110px 1fr 130px;
    gap: 16px;
    margin-bottom: 10px;
    font-size: 11px;
    opacity: 0.55;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .head .right { text-align: right; }
  .row {
    display: grid;
    grid-template-columns: 110px 1fr 130px;
    gap: 16px;
    padding: 16px 0;
    border-top: 1px dashed var(--rule);
    align-items: baseline;
  }
  .when {
    font-size: 12px;
    opacity: 0.7;
    line-height: 1.4;
  }
  .title-link { color: var(--ink); }
  .title-link:hover { text-decoration: none; }
  .title-link h3 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .title-link:hover h3 {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }
  .dek {
    margin: 8px 0 0;
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.55;
    opacity: 0.85;
    max-width: 640px;
  }
  .meta-right {
    text-align: right;
    font-size: 12px;
    line-height: 1.7;
    opacity: 0.7;
  }
  .words { opacity: 0.6; }
  .empty { margin-top: 24px; opacity: 0.7; }

  @media (max-width: 820px) {
    .hero { grid-template-columns: 1fr; }
    .fig .field { width: 100%; max-width: 380px; }
    .head, .row { grid-template-columns: 90px 1fr 100px; }
  }
  @media (max-width: 560px) {
    .head { display: none; }
    .row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .meta-right { text-align: left; }
  }
</style>
