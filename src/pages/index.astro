---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostPreview from '../components/PostPreview.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE } from '../consts';

const posts = (await getPublishedPosts()).slice(0, 5);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <main>
    <section class="intro">
      <h1>Stephen McAnearney</h1>
      <p class="positioning">{SITE.positioning}</p>
      <p class="bio">
        Stephen is a product leader and investor working at the intersection of deep technology
        and frontier hardware. Most recently a Senior Product Manager at Meta, where he shipped the
        Meta Neural Band and the Meta Ray-Ban Display glasses and contributed to research published
        in Nature. Earlier work spans the Harvard Surgical Planning Lab, technology investment
        banking at JPMorgan, and venture capital at Hone Capital. He is relocating to Perth to back
        and build deep tech companies in Western Australia.
      </p>
    </section>

    <section class="writing">
      <div class="section-head">
        <span class="eyebrow">Writing</span>
        <a href="/writing">All posts →</a>
      </div>
      {
        posts.length > 0 ? (
          <div class="post-list">
            {posts.map((post) => (
              <PostPreview post={post} />
            ))}
          </div>
        ) : (
          <p class="empty">Posts are on the way.</p>
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 72px var(--gutter) 88px;
  }
  .intro h1 {
    font-size: clamp(1.9rem, 1.6rem + 1.5vw, 2.3rem);
  }
  .positioning {
    margin-top: 14px;
    font-size: 1.08rem;
    color: var(--fg-strong);
  }
  .bio {
    margin-top: 20px;
    color: var(--fg-muted);
  }
  .writing {
    margin-top: 64px;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }
  .section-head a {
    font-size: 0.85rem;
    color: var(--fg-faint);
    transition: color 0.15s ease;
  }
  .section-head a:hover {
    color: var(--fg);
    text-decoration: none;
  }
  .post-list {
    margin-top: 8px;
    border-top: 1px solid var(--border);
  }
  .empty {
    margin-top: 20px;
    color: var(--fg-muted);
  }
</style>
