---
import { SITE, SOCIAL } from '../consts';

const year = new Date().getFullYear();

const links = [
  { label: 'Email', href: `mailto:${SOCIAL.email}`, rel: undefined },
  { label: 'LinkedIn', href: SOCIAL.linkedin, rel: 'me' },
  { label: 'GitHub', href: SOCIAL.github, rel: 'me' },
  { label: 'RSS', href: SOCIAL.rss, rel: undefined },
];
---

<footer transition:persist>
  <div class="inner">
    <nav class="links" aria-label="Elsewhere">
      {links.map((l) => <a href={l.href} rel={l.rel}>{l.label}</a>)}
    </nav>
    <div class="meta">
      <span>&copy; {year} {SITE.author}</span>
      <span class="eyebrow">Perth · Western Australia</span>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
  }
  .inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 28px var(--gutter) 44px;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  .links a {
    font-size: 0.92rem;
    color: var(--fg-muted);
    transition: color 0.15s ease;
  }
  .links a:hover {
    color: var(--fg-strong);
  }
  .meta {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    justify-content: space-between;
    font-size: 0.84rem;
    color: var(--fg-faint);
  }
</style>
