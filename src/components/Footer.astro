---
import AsciiRule from './AsciiRule.astro';
const stamp = new Date().toISOString().slice(0, 16).replace('T', ' ');
---

<footer>
  <AsciiRule />
  <div class="row">
    <span class="stamp">last build {stamp} AWST</span>
    <span class="rights">cc by-nc 4.0 · 2025–26</span>
  </div>
</footer>

<style>
  footer {
    max-width: var(--page-width);
    margin: 64px auto 0;
    padding: 0 var(--gutter) 56px;
  }
  .row {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    opacity: 0.6;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
    align-items: flex-start;
  }
  .stamp { letter-spacing: 0.04em; opacity: 0.92; }
  .rights { color: var(--accent); }
</style>
