---
import { NAV } from '../consts';
import AsciiRule from './AsciiRule.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header>
  <div class="row">
    <a href="/" class="brand" aria-label="Building 58 — home">
      <h1>Building&nbsp;58<span class="cursor">_</span></h1>
    </a>
    <nav aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[{ active: isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
  <div class="rule"><AsciiRule /></div>
</header>

<style>
  header {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 28px var(--gutter) 0;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: baseline;
  }
  .brand { color: inherit; }
  .brand:hover { text-decoration: none; }
  .brand h1 {
    margin: 6px 0 0;
    font-family: var(--font-mono);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .cursor { color: var(--accent); }
  nav {
    font-family: var(--font-mono);
    font-size: 13px;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }
  nav a {
    color: var(--ink);
    opacity: 0.78;
  }
  nav a.active {
    color: var(--accent);
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .rule { margin-top: 18px; }
  @media (max-width: 560px) {
    .row { grid-template-columns: 1fr; gap: 8px; }
    .brand h1 { font-size: 24px; }
  }
</style>
