---
import BaseLayout from './BaseLayout.astro';
import AsciiRule from '../components/AsciiRule.astro';
import { dotDate } from '../lib/format';

interface PostLink {
  id: string;
  title: string;
}

interface Props {
  slug: string;
  issue: string;
  title: string;
  dek: string;
  description: string;
  pubDate: Date;
  words: number;
  read: string;
  newer?: PostLink;
  older?: PostLink;
}

const { slug, issue, title, dek, description, pubDate, words, read, newer, older } =
  Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={`/og/${slug}.png`}
  type="article"
  publishedTime={pubDate}
>
  <main>
    <article>
      <header class="mast">
        <div class="mast-meta">
          <span>№ {issue}</span>
          <span>·</span>
          <span>{dotDate(pubDate)}</span>
          <span>·</span>
          <span>{read} · {words.toLocaleString()} words</span>
        </div>
        <h1 transition:name={`post-${slug}`}>{title}</h1>
        <p class="dek">{dek}</p>
      </header>

      <div class="essay-body">
        <slot />
      </div>

      <div class="footer">
        <AsciiRule />
        <div class="nav">
          <div>
            <div class="label">previous</div>
            {
              older ? (
                <a href={`/writing/${older.id}`}>← {older.title}</a>
              ) : (
                <span class="empty">— first essay —</span>
              )
            }
          </div>
          <div class="right">
            <div class="label">next</div>
            {
              newer ? (
                <a href={`/writing/${newer.id}`}>{newer.title} →</a>
              ) : (
                <span class="empty">— this is the latest —</span>
              )
            }
          </div>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 28px var(--gutter) 56px;
    font-family: var(--font-mono);
    color: var(--ink);
  }

  .mast { margin-top: 28px; }
  .mast-meta {
    display: flex;
    gap: 14px;
    font-size: 12px;
    opacity: 0.7;
    flex-wrap: wrap;
  }
  .mast h1 {
    margin: 18px 0 14px;
    max-width: 760px;
    font-size: 32px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .dek {
    max-width: 760px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: calc(var(--base) + 5px);
    line-height: 1.45;
    color: var(--soft);
    text-wrap: pretty;
  }
  .essay-body {
    margin-top: 28px;
    max-width: 980px;
    padding-right: 260px;
  }
  .essay-body :global(h2) {
    margin: 36px 0 18px;
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .essay-body :global(p) {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
    text-wrap: pretty;
  }
  .essay-body :global(em) { font-style: italic; }
  @media (max-width: 980px) {
    .essay-body { padding-right: 0; max-width: var(--prose-width); }
  }

  .footer { margin-top: 36px; max-width: 980px; }
  .nav {
    margin-top: 14px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .nav .right { text-align: right; }
  .nav .label {
    opacity: 0.55;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .nav a {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }
  .nav .empty { opacity: 0.5; }
</style>
